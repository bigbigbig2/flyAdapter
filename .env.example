# GR3 adapter defaults. Keep namespace aligned with HumanoidNav startup.
ROBOT_NAMESPACE=GR301AA0025
ADAPTER_HOST=0.0.0.0
ADAPTER_PORT=8080

# Unified map naming. A map_name resolves to: ${MAP_ROOT}/${map_name}.
# The robot's built-in default is usually /opt/fftai/nav/map.
# DEFAULT_MAP_PATH is optional; if unset, Adapter uses ${MAP_ROOT}/${DEFAULT_MAP_NAME}.
MAP_ROOT=/opt/fftai/nav
DEFAULT_MAP_NAME=map
# DEFAULT_MAP_PATH=/opt/fftai/nav/map
ADAPTER_DATA_DIR=./data
# Saving a 3D map can take much longer than a normal ROS service call.
MAP_SAVE_TIMEOUT_SEC=120

# Motion ownership policy:
# none    = default. Mapping/POI movement is done by remote controller; auto nav sends Nav2 goals only.
# observe = poll Aurora state for diagnostics, but never use Aurora to command motion.
# aurora  = require Aurora Agent and call ensure_stand/stop_motion around autonomous navigation.
MOTION_GUARD=none
REQUIRE_AURORA=0
# AURORA_ENABLED is forced on automatically when MOTION_GUARD is observe/aurora.
AURORA_ENABLED=0
AURORA_BACKEND=agent
AURORA_AGENT_URL=http://127.0.0.1:18080
# Must match AuroraCore config/config.yaml exactly.
AURORA_ROBOT_NAME=gr3v233
AURORA_DOMAIN_ID=123
AURORA_STAND_FSM_STATE=2
AURORA_POLL_INTERVAL_SEC=1.0
AURORA_STATE_TIMEOUT_SEC=2.0
AURORA_COMMAND_TIMEOUT_SEC=3.0
AURORA_STATE_STALE_SEC=5.0
AURORA_CIRCUIT_FAILURE_THRESHOLD=3
AURORA_CIRCUIT_OPEN_SEC=5.0

# Only Aurora Agent needs these SDK settings. The main adapter does not import
# Aurora SDK directly.
AURORA_SDK_PATH=
AURORA_CLIENT_MODULE=fourier_aurora_client
AURORA_CLIENT_CLASS=AuroraClient
# Agent startup clears inherited HumanoidNav overlays by default because that
# workspace has a navigation-only fourier_msgs package without AuroraCmd.
AURORA_ENV_CLEAN=1
# Optional: source the real Aurora SDK setup before the Agent starts.
AURORA_SETUP_SCRIPT=

# Set AURORA_MOCK=1 only for local adapter UI/API testing.
AURORA_MOCK=0
